{
  "name": "@org/payment-service",
  "projectType": "application",
  "sourceRoot": "apps/payment-service/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/payment-service",
        "format": ["cjs"],
        "bundle": true,
        "main": "apps/payment-service/src/main.ts",
        "tsConfig": "apps/payment-service/tsconfig.app.json",
        "assets": ["apps/payment-service/src/assets"],
        "generatePackageJson": false,
        "esbuildOptions": {
          "sourcemap": true
        }
      },
      "configurations": {
        "development": {
          "sourcemap": true
        },
        "production": {
          "sourcemap": false,
          "minify": true
        }
      }
    },

    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "@org/payment-service:build",
        "watch": true
      },
      "configurations": {
        "development": {
          "buildTarget": "@org/payment-service:build:development"
        },
        "production": {
          "buildTarget": "@org/payment-service:build:production"
        }
      }
    },

    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },

  "test": {
  "executor": "@nx/jest:jest",
  "outputs": [
    "{workspaceRoot}/coverage/{projectRoot}"
  ],
  "options": {
    "jestConfig": "apps/payment-service/jest.config.cts",
    "passWithNoTests": true
  }
}
  },
   "dependencies": {
    "express": "^4.21.2"
  }
}